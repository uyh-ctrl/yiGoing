# Copy this file to .env (or configure the same variables in your deployment platform).
# Never commit .env, private keys, certificates, or production passwords.

# Shared deployment
SPRING_PROFILES_ACTIVE=prod
EASYGOING_PUBLIC_BASE_URL=https://mall.example.com
EASYGOING_JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters

# Admin database / Redis / OSS
EASYGOING_DB_URL=jdbc:mysql://db.example.com:3306/mall?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
EASYGOING_DB_USERNAME=mall_app
EASYGOING_DB_PASSWORD=replace-with-db-password
EASYGOING_REDIS_HOST=redis.example.com
EASYGOING_REDIS_PORT=6379
EASYGOING_REDIS_PASSWORD=replace-with-redis-password
EASYGOING_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
EASYGOING_OSS_ACCESS_KEY_ID=replace-with-oss-access-key-id
EASYGOING_OSS_ACCESS_KEY_SECRET=replace-with-oss-access-key-secret
EASYGOING_OSS_BUCKET=mall-production
EASYGOING_OSS_ENABLED=false

# AI customer service (OpenAI-compatible endpoint)
EASYGOING_AI_ENABLED=false
EASYGOING_AI_BASE_URL=https://api.openai.com
EASYGOING_AI_API_KEY=replace-with-ai-api-key
EASYGOING_AI_CHAT_MODEL=gpt-4.1-mini
EASYGOING_AI_EMBEDDING_MODEL=text-embedding-3-small

# Portal services
EASYGOING_PORTAL_DB_URL=jdbc:mysql://db.example.com:3306/mall?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
EASYGOING_PORTAL_DB_USERNAME=mall_app
EASYGOING_PORTAL_DB_PASSWORD=replace-with-db-password
EASYGOING_PORTAL_REDIS_HOST=redis.example.com
EASYGOING_PORTAL_REDIS_PORT=6379
EASYGOING_PORTAL_REDIS_PASSWORD=replace-with-redis-password
EASYGOING_MONGODB_URI=mongodb://mall_app:replace-with-mongodb-password@mongo.example.com:27017/mall-port?authSource=admin
EASYGOING_RABBITMQ_HOST=rabbitmq.example.com
EASYGOING_RABBITMQ_PORT=5672
EASYGOING_RABBITMQ_VHOST=/mall
EASYGOING_RABBITMQ_USERNAME=mall_app
EASYGOING_RABBITMQ_PASSWORD=replace-with-rabbitmq-password
EASYGOING_ELASTICSEARCH_URIS=http://elasticsearch.example.com:9200

# Alipay Page Pay: obtain these values from Alipay Open Platform.
EASYGOING_ALIPAY_ENABLED=false
EASYGOING_ALIPAY_APP_ID=2021000000000000
EASYGOING_ALIPAY_PRIVATE_KEY=replace-with-pkcs8-rsa-private-key
EASYGOING_ALIPAY_PUBLIC_KEY=replace-with-alipay-public-key
EASYGOING_ALIPAY_NOTIFY_URL=https://mall.example.com/payment/alipay/notify
EASYGOING_ALIPAY_RETURN_URL=https://mall.example.com/#/payment/result

# WeChat Pay v3 Native: store certificate/private key by secret manager in production.
EASYGOING_WECHAT_PAY_ENABLED=false
EASYGOING_WECHAT_PAY_APP_ID=wx0000000000000000
EASYGOING_WECHAT_PAY_MCH_ID=1900000001
EASYGOING_WECHAT_PAY_MCH_SERIAL_NO=replace-with-merchant-certificate-serial-no
EASYGOING_WECHAT_PAY_PRIVATE_KEY=replace-with-merchant-private-key
EASYGOING_WECHAT_PAY_API_V3_KEY=replace-with-32-byte-api-v3-key
EASYGOING_WECHAT_PAY_PLATFORM_CERTIFICATE=replace-with-wechatpay-platform-certificate
EASYGOING_WECHAT_PAY_NOTIFY_URL=https://mall.example.com/payment/wechat/notify
